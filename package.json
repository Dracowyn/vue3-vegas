{
  "name": "vue3-vegas",
  "version": "0.2.0",
  "type": "module",
  "description": "Vegas.js for Vue 3 — a full-screen slideshow/background component",
  "author": "Dracowyn",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Dracowyn/vue3-vegas"
  },
  "homepage": "https://github.com/Dracowyn/vue3-vegas#readme",
  "bugs": {
    "url": "https://github.com/Dracowyn/vue3-vegas/issues"
  },
  "keywords": [
    "vue",
    "vue3",
    "vegas",
    "slideshow",
    "background",
    "transition",
    "carousel"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "rslib build && vue-tsc",
    "dev": "rslib --watch",
    "prepublishOnly": "pnpm run build",
    "storybook": "storybook dev",
    "build-storybook": "storybook build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@rslib/core": "^0.23.0",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/addon-onboarding": "^10.4.6",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/test-utils": "^2.4.11",
    "jsdom": "^29.1.1",
    "rsbuild-plugin-unplugin-vue": "^0.2.0",
    "storybook": "^10.4.6",
    "storybook-addon-rslib": "^3.3.4",
    "storybook-vue3-rsbuild": "^3.3.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9",
    "vue": "^3.5.38",
    "vue-tsc": "^3.3.5"
  },
  "peerDependencies": {
    "vue": "^3.2.0"
  }
}
